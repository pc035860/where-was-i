{
  "name": "wwi",
  "version": "0.1.0",
  "type": "module",
  "description": "Where Was I? — Track your AI coding agents",
  "bin": {
    "wwi": "./bin/wwi"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "openai": "^6.31.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
